# Risk Agent Environment Configuration
# Copy this file to .env and update values for your environment

# ── Server Configuration ──────────────────────────────────────────────────────
HOST=127.0.0.1
PORT=8000
UVICORN_RELOAD=0

# ── CORS Configuration ───────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8080", "http://localhost:5173"]
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=["GET", "POST", "PUT", "DELETE", "OPTIONS"]
CORS_ALLOW_HEADERS=["*"]

# ── Database Configuration ───────────────────────────────────────────────────
DATABASE_URL=postgresql://risk_agent:password@localhost:5432/risk_agent
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ── Redis Cache Configuration ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=3600
CACHE_ENABLED=true

# ── Authentication Configuration ─────────────────────────────────────────────
SECRET_KEY=your-super-secret-key-change-this-in-production-minimum-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ── API Key Configuration ────────────────────────────────────────────────────
API_KEY_HEADER=X-API-Key
API_KEYS=["your-api-key-1", "your-api-key-2"]

# ── Rate Limiting Configuration ──────────────────────────────────────────────
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# ── LLM Configuration ───────────────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama2
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-3-sonnet-20240229

# ── Logging Configuration ───────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s | %(levelname)s | %(name)s | %(message)s

# ── Health Check Configuration ──────────────────────────────────────────────
HEALTH_CHECK_DATABASE=true
HEALTH_CHECK_CACHE=true
HEALTH_CHECK_LLM=true

# ── Feature Flags ───────────────────────────────────────────────────────────
ENABLE_BATCH_PROCESSING=true
ENABLE_CACHING=true
ENABLE_AUTHENTICATION=false
ENABLE_RATE_LIMITING=true